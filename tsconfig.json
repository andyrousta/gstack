{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    // personal: makes debugging easier during development
    "pretty": true,
    // personal: helps catch accidental any usage while learning the codebase
    "noImplicitAny": true
  },
  "include": ["src/**/*"],
  // also exclude test helpers/fixtures from compilation
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "**/__fixtures__/**"]
}
